# Facebook Page assets — JSON array of page configurations
# Get tokens from https://developers.facebook.com/tools/explorer
#
# Fields:
#   fb_page_id        — Facebook Page ID
#   page_name         — slug identifier (lowercase, no spaces), used as first param in all tools/commands
#   display_name      — human-readable label
#   page_access_token — Page access token
#
FACEBOOK_ASSETS='[{"fb_page_id":"123456789","page_name":"mybusiness","display_name":"My Business Page","page_access_token":"EAAxxxxxxx..."},{"fb_page_id":"987654321","page_name":"sideproject","display_name":"Side Project","page_access_token":"EAAyyyyyyy..."}]'

# Optional: Graph API version override (default: v25.0)
# FB_API_VERSION=v25.0

# Optional: HTTP safety controls (anti-spam / resilience)
# FB_HTTP_MAX_RATE_LIMIT_RETRIES=4
# FB_HTTP_MAX_SERVER_RETRIES=2
# FB_HTTP_RETRY_BASE_DELAY_MS=500
# FB_HTTP_RETRY_MAX_DELAY_MS=10000
# FB_HTTP_RETRY_JITTER_RATIO=0.2
# FB_HTTP_CIRCUIT_BREAKER_ENABLED=true
# FB_HTTP_CIRCUIT_FAILURE_THRESHOLD=5
# FB_HTTP_CIRCUIT_COOLDOWN_MS=30000
# FB_HTTP_CIRCUIT_HALF_OPEN_SUCCESSES=1
# FB_HTTP_GLOBAL_MIN_INTERVAL_MS=50
# FB_HTTP_TOKEN_MIN_INTERVAL_MS=150
