{
  "name": "facebook-mcp-cli",
  "version": "2.0.0",
  "description": "Facebook Page Management MCP server & CLI tools",
  "type": "module",
  "scripts": {
    "start": "bun run src/server.ts",
    "cli": "bun run cli/fbcli.ts",
    "test": "bun test",
    "verify": "bash scripts/verify.sh",
    "lint": "oxlint -c ./.oxlintrc.json src cli tests scripts",
    "lint:all": "oxlint -c ./.oxlintrc.json src cli tests scripts",
    "format": "oxfmt --ignore-path .gitignore --ignore-path .oxfmtignore",
    "format:check": "oxfmt --check --ignore-path .gitignore --ignore-path .oxfmtignore .",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "cli-table3": "^0.6.5",
    "csv-stringify": "^6.6.0",
    "js-yaml": "^4.1.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "lefthook": "^2.1.2",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0"
  }
}
