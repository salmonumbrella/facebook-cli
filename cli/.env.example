# OAuth app credentials for `fbcli auth login`
FB_APP_ID="your_meta_app_id"
FB_APP_SECRET="your_meta_app_secret"
FB_OAUTH_REDIRECT_URI="http://localhost:8484/callback"
# Optional overrides
# FB_OAUTH_TIMEOUT_MS=180000
# FB_OAUTH_SCOPES="public_profile,pages_show_list,pages_read_engagement,pages_manage_posts,ads_read,ads_management,business_management"
# FB_API_VERSION="v25.0"

# Optional: explicit page assets for legacy page commands.
# If omitted, `fbcli pages` and the older page commands will attempt to derive
# page IDs and page access tokens from your logged-in OAuth profile.
# FACEBOOK_ASSETS='[{"fb_page_id":"123456789","page_name":"mybusiness","display_name":"My Business Page","page_access_token":"EAAxxxxxxx..."}]'

# Optional: explicit user token for non-interactive use.
# FB_ACCESS_TOKEN="EAA..."
# FB_USER_ACCESS_TOKEN="EAA..."
